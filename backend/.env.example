MONGO_URI=mongodb://localhost:27017/affiliate_engine
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
CRYPTO_SECRET=your_32_byte_encryption_secret_here

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash

# Redis Connection for BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Worker Concurrency (tune based on OpenRouter plan limits)
DEPLOY_WORKER_CONCURRENCY=15
STATIC_DEPLOY_WORKER_CONCURRENCY=15
CSV_PROCESSOR_CONCURRENCY=3
